# Required. Create a key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Low-cost, consistent model for evaluation and question selection.
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# Local speech defaults (CPU-friendly for development).
WHISPER_MODEL=tiny.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
# STT_LANGUAGE=en
TTS_RATE=175
